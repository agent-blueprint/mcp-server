{
  "name": "agentblueprint",
  "version": "0.7.16",
  "description": "8 MCP tools for exploring and downloading AI agent blueprints. List blueprints, get summaries, download full Agent Skills directories for implementation by coding agents. Vendor-agnostic output works with ServiceNow, Salesforce, OpenClaw, or any platform.",
  "type": "module",
  "bin": {
    "agentblueprint": "dist/cli.js",
    "agent-blueprint-mcp": "dist/index.js"
  },
  "main": "dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./renderers": "./dist/renderers.js",
    "./types": "./dist/types.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "cli",
    "agent-blueprint",
    "ai",
    "blueprint",
    "model-context-protocol"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/agent-blueprint/mcp-server"
  },
  "homepage": "https://agentblueprint.ai/developers",
  "mcpName": "io.github.agent-blueprint/mcp-server",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.0",
    "js-yaml": "^4.1.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "typescript": "^5.5.0",
    "vitest": "^3.0.0"
  }
}
